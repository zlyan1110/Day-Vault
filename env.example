# ===========================================
# DayVault - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ----- Supabase -----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx   # Project Settings → API → Publishable key (safe for client-side)
SUPABASE_SECRET_KEY=sb_secret_xxxx             # Project Settings → API → Secret key (backend only, never expose)

# ----- OpenAI -----
OPENAI_API_KEY=sk-your-openai-api-key

# ----- Backend -----
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ----- Frontend -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx   # Same as SUPABASE_PUBLISHABLE_KEY above
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----- Qdrant (V1+) -----
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key

# ----- Inference (V2+) -----
# VLLM_API_URL=http://localhost:8001/v1
# SGLANG_API_URL=http://localhost:8002/v1
# INFERENCE_BACKEND=openai  # openai | vllm | sglang | trtllm | triton
